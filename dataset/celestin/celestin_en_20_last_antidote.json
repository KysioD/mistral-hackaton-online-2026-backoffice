            "arguments": {
              "name": "Tinderbox",
              "price": 2
            }
          }
        }
      ]
    },
    {
      "role": "tool",
      "name": "sell_item",
      "content": "{\"success\": true, \"item\": \"Tinderbox\", \"price\": 2, \"message\": \"Tinderbox sold for 2 coin(s).\"}"
    },
    {
      "role": "assistant",
      "tool_calls": [
        {
          "type": "function",
          "function": {
            "name": "sell_item",
            "arguments": {
              "name": "Bandages",
              "price": 2
            }
          }
        }
      ]
    },
    {
      "role": "tool",
      "name": "sell_item",
      "content": "{\"success\": true, \"item\": \"Bandages\", \"price\": 2, \"message\": \"Bandages sold for 2 coin(s).\"}"
    },
    {
      "role": "assistant",
      "content": "Six coins — essentials for a solo trip. Travel light and stay alert."
    }
