// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Tool {
  id          String          @id @default(cuid())
  name        String          @unique
  description String
  parameters  ToolParameter[]
  npcs        NpcTool[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ToolParameter {
  id          String  @id @default(cuid())
  toolId      String
  name        String
  description String
  required    Boolean @default(false)

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([toolId, name])
}

model SystemPrompt {
  id        String   @id @default(cuid())
  name      String   @unique
  content   String
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Npc {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  prefab          String
  spawnX          Float
  spawnY          Float
  spawnZ          Float
  spawnRotation   Float
  characterPrompt String
  tools           NpcTool[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions Session[]

  @@unique([firstName, lastName])
}

model NpcTool {
  id     String @id @default(cuid())
  npcId  String
  toolId String

  npc  Npc  @relation(fields: [npcId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([npcId, toolId])
}

model Session {
  id         String    @id @default(cuid())
  npcId      String
  tokensUsed Int       @default(0)
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  npc      Npc       @relation(fields: [npcId], references: [id], onDelete: Cascade)
  messages Message[]
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model Message {
  id              String   @id @default(cuid())
  sessionId       String
  role            Role
  content         String
  toolCalls       Json?
  toolCallId      String?
  createdAt       DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
